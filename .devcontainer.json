{
  "customizations": {
    "vscode": {
      "extensions": [
        "lfs.vscode-emacs-friendly",
        "Anthropic.claude-code",
        "golang.go",
        "alexkrechik.cucumberautocomplete"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "silo",
        "terminal.integrated.profiles.linux": {
          "silo": {
            "path": "${userHome}/.nix-profile/bin/default-shell"
          }
        }
      }
    }
  },
  "image": "silo-xqmrs9xj",
  "mounts": [
    "type=volume,source=silo-shared,target=/home/markus/.local/share/fish/fish_history,subpath=home/markus/.local/share/fish/fish_history,z",
    "type=volume,source=silo-shared,target=/home/markus/.claude.json,subpath=home/markus/.claude.json,z",
    "type=volume,source=silo-shared,target=/home/markus/.claude,subpath=home/markus/.claude,z"
  ],
  "name": "silo-xqmrs9xj-dev",
  "overrideCommand": true,
  "remoteUser": "markus",
  "runArgs": [
    "--name",
    "silo-xqmrs9xj-dev",
    "--hostname",
    "silo-xqmrs9xj-dev",
    "--cap-drop=ALL",
    "--cap-add=NET_BIND_SERVICE",
    "--security-opt",
    "no-new-privileges"
  ],
  "workspaceFolder": "/workspace/xqmrs9xj/silo",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/xqmrs9xj/silo,type=bind,z"
}
