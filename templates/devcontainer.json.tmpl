{
  "name": "{{.ContainerName}}",
  "image": "{{.Image}}",
  "remoteUser": "{{.User}}",
  "runArgs": {{json .ContainerArgs}},
  "overrideCommand": true,
  "workspaceFolder": "{{.WorkspaceMount}}",
  "workspaceMount": "source=${localWorkspaceFolder},target={{.WorkspaceMount}},type=bind,Z"
  {{- if .SharedVolumeName }},
  "mounts": [
    {{- range $i, $path := .SharedVolumePaths}}
    {{- if $i}},{{- end}}
    "type=volume,source={{$.SharedVolumeName}},target={{$path}},subpath={{trimPrefix $path "/"}},Z"
    {{- end}}
  ]
  {{- end}}
}